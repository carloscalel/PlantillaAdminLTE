@model ASP.NET.MVC_NETFramework.Models.Department

<div class="form-group">
    @Html.LabelFor(m => m.Name)
    @Html.TextBoxFor(m => m.Name, new { @class = "form-control", maxlength = 50 })
    @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
</div>

<div class="form-group">
    @Html.LabelFor(m => m.GroupName)
    @Html.TextBoxFor(m => m.GroupName, new { @class = "form-control", maxlength = 50 })
    @Html.ValidationMessageFor(m => m.GroupName, "", new { @class = "text-danger" })
</div>
